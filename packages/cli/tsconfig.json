{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "module": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "es2022",
    "moduleResolution": "nodenext",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "skipLibCheck": true
  },
  "include": ["./src/**/*"],
  "ts-node": {
    "esm": true
  }
}
