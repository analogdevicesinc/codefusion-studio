{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out",
    "rootDir": "src",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": false
  },
  "include": ["src/tests/unit/**/*.ts"],
  "exclude": ["node_modules"]
}
