{
	"compilerOptions": {
		"composite": true,
		"noEmit": true,
		"target": "es2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"types": ["cypress", "cypress-real-events"],
		"module": "ESNext",
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"@common/*": ["./common/*"],
			"@ide-types/*": ["../types/*"],
			"@constants/*": ["../constants/*"],
			"@socs/*": ["../../../cfs-data-models/socs/*"]
		},
		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",

		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": [
		"./**/*.ts",
		"./**/*.tsx",
		"./cypress.d.ts",
		"../types/**/*.ts",
		"../constants/**/*.ts"
	]
}
