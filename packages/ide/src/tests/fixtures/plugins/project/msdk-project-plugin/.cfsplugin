{
  "pluginName": "MSDK Project Plugin",
  "pluginDescription": "MSDK project and code generation.",
  "pluginId": "com.analog.project.msdk.mock.plugin",
  "pluginVersion": "1.1.0",
  "schemaVersion": "1.1.0",
  "pluginApiVersion": 1,
  "author": "Analog Devices, Inc.",
  "firmwarePlatform": "MSDK",
  "supportedSocs": [
    {
      "name": "MAX32690",
      "board": "EvKit_V1",
      "package": "tqfn"
    },
    {
      "name": "MAX32690",
      "board": "FTHR",
      "package": "tqfn"
    },
    {
      "name": "MAX32690",
      "board": "AD-APARD32690-SL",
      "package": "wlp"
    },
    {
      "name": "MAX78002",
      "board": "EvKit_V1",
      "package": "csbga"
    }
  ],
  "features": {
    "project": {
      "templates": [],
      "files": []
    },
    "codegen": {
      "files": [],
      "templates": [
        {
          "src": "mock/generated-code-path.eta",
          "dst": "generated/${context.coreId.toLowerCase()}/generated-file.txt"
        }
      ]
    }
  },
  "properties": {
    "project": [
      {
        "id": "ProjectName",
        "name": "Project Name",
        "category": "Project Settings",
        "default": "${context.coreId}",
        "type": "string",
        "required": true,
        "readonly": false
      },
      {
        "id": "MsdkBoardName",
        "name": "MSDK Board Name",
        "category": "Project Settings",
        "default": "",
        "type": "string",
        "required": true,
        "readonly": false
      },
      {
        "id": "Cflags",
        "name": "CFLAGS",
        "type": "textarea",
        "default": "-fdump-rtl-expand\n-fdump-rtl-dfinish\n-fdump-ipa-cgraph\n-fstack-usage\n-gdwarf-4\n",
        "readonly": "true"
      }
    ],
    "clockConfig": {
      "ADC": {
        "defaultOverrides": [
          {
            "Id": "DIV",
            "Value": "8",
            "partRegexp": "MAX(32650|32655|32666|78000)"
          }
        ]
      },
      "AOD_CLK": {
        "modifiedControls": [
          {
            "Id": "DIV",
            "Description": "Divider Value",
            "EnumValues": [
              {
                "Id": "4",
                "Description": "Divide by 4",
                "Value": 0
              }
            ],
            "Type": "enum",
            "partRegexp": "MAX32675C"
          }
        ]
      },
      "SYS_OSC Mux": {
        "defaultOverrides": [
          {
            "Id": "MUX",
            "Value": "IPO",
            "partRegexp": "MAX(32655|32657|32658|32690)"
          },
          {
            "Id": "MUX",
            "Value": "HSCLK",
            "partRegexp": "MAX32650"
          },
          {
            "Id": "MUX",
            "Value": "HSO",
            "partRegexp": "MAX32666"
          }
        ]
      },
      "IPO": {
        "removedControls": [
          {
            "Id": "CALIBRATE",
            "partRegexp": "MAX(32650|32655|32657|32658|32660|32666|32670|32672|32675C|78000|78002)"
          }
        ]
      },
      "IPO PRESCALER": {
        "modifiedControls": [
          {
            "Id": "DIV",
            "Description": "Divider Value",
            "EnumValues": [
              {
                "Id": "1",
                "Description": "Divide by 1",
                "Value": 0
              }
            ],
            "Type": "enum",
            "partRegexp": "MAX(32662|32670|32675C)"
          }
        ]
      },
      "INRO": {
        "removedControls": [
          {
            "Id": "INRO_FREQ",
            "partRegexp": "MAX(32655|78000|78002)"
          }
        ]
      },
      "TMR0/1/2/3": {
        "defaultOverrides": [
          {
            "Id": "TMR0b_MUX",
            "Value": "32BIT"
          },
          {
            "Id": "TMR1b_MUX",
            "Value": "32BIT"
          },
          {
            "Id": "TMR2b_MUX",
            "Value": "32BIT"
          },
          {
            "Id": "TMR3b_MUX",
            "Value": "32BIT"
          }
        ]
      },
      "LPTMR[01]": {
        "modifiedControls": [
          {
            "Id": "MUX",
            "Description": "Clock Source",
            "Type": "enum",
            "Condition": "${Control:ENABLE}",
            "partRegexp": "MAX32670",
            "EnumValues": [
              {
                "Id": "ERTCO",
                "Description": "ERTCO (External RTC Osc.)",
                "Value": 1
              },
              {
                "Id": "INRO",
                "Description": "INRO (Internal Nano-Ring Osc.)",
                "Value": 3
              },
              {
                "Id": "EXT_CLK2",
                "Description": "EXT_CLK2 (External Clock Two)",
                "Value": 4
              }
            ]
          }
        ],
        "defaultOverrides": [
          {
            "Id": "MUX",
            "Value": "ERTCO",
            "partRegexp": "MAX32670"
          }
        ]
      },
      "LPUART0": {
        "modifiedControls": [
          {
            "Id": "MUX",
            "EnumValues": [
              {
                "Id": "AOD_CLK",
                "Description": "Always on Domain Clock",
                "Value": 0
              },
              {
                "Id": "P0.12 AF2",
                "Description": "External Clock on P0.12 AF2",
                "Value": 6
              }
            ],
            "Type": "enum",
            "partRegexp": "MAX32675C"
          }
        ]
      },
