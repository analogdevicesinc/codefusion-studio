{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "cfgtools: build",
			"type": "shell",
			"command": "yarn cfgtools:build-dev",
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				{
					"pattern": {
						"regexp": ".*",
						"file": 1,
						"location": 2,
						"message": 3
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": "vite v[0-9\\.]+ building",
						"endsPattern": "built in [0-9\\.]+m?s"
					}
				}
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"showReuseMessage": true,
				"clear": true
			},
			"dependsOn": ["extension: build", "react-lib: build"]
		},
