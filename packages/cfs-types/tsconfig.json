{
	"compilerOptions": {
		"composite": true,
		"declaration": true,
		"module": "NodeNext",
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"target": "es2022",
		"moduleResolution": "NodeNext",
		"tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": ["./src/**/*"]
}
