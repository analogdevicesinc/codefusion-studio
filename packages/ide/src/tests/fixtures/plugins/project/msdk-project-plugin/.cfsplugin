              },
              {
                "Id": "IPO",
                "Description": "IPO (Internal Primary Osc.)",
                "Value": 1
              },
              {
                "Id": "IBRO",
                "Description": "IBRO (Internal Baud Rate Osc.)",
                "Value": 2
              },
              {
                "Id": "INRO",
                "Description": "INRO (Internal Nano-Ring Osc.)",
                "Value": 3
              }
            ],
            "Type": "enum",
            "partRegexp": "MAX32675C"
          },
          {
            "Id": "WDT1_MUX",
            "EnumValues": [
              {
                "Id": "PCLK",
                "Description": "PCLK (Peripheral Clock)",
                "Value": 0
              },
              {
                "Id": "IPO",
                "Description": "IPO (Internal Primary Osc.)",
                "Value": 1
              },
              {
                "Id": "IBRO",
                "Description": "IBRO (Internal Baud Rate Osc.)",
                "Value": 2
              },
              {
                "Id": "INRO",
                "Description": "INRO (Internal Nano-Ring Osc.)",
                "Value": 3
              }
            ],
            "Type": "enum",
            "partRegexp": "MAX32675C"
          }
        ]
      }
    },
